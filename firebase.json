{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "docs"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "node scripts/build-audio.js",
      "node scripts/bump-version.js",
      "node scripts/obfuscate.js"
    ],
    "postdeploy": [
      "node scripts/restore.js",
      "node scripts/deploy-cloudflare.js"
    ]
  }
}