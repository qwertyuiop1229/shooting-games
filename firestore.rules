rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ランキング用の共通バリデーション =====
    // 書き込みデータの整合性チェック（認証済み＋自分のUID＋スコア上限）
    function isValidRankingWrite() {
      let d = request.resource.data;
      return request.auth != null
          && d.uid == request.auth.uid
          && d.score is number
          && d.score >= 0
          && d.playTimeSeconds is number
          && d.playTimeSeconds >= 0
          && d.playTimeSeconds <= 10800
          && d.score <= d.playTimeSeconds * 300
          && d.name is string
          && d.name.size() <= 12;
    }

    // 自分のドキュメントか（UID一致）、またはレガシーデータ（UIDフィールド未設定）
    function isOwnerOrLegacy() {
      return resource.data.uid == request.auth.uid
          || !('uid' in resource.data);
    }

    // rankings, rankings_easy, rankings_hard 共通ルール
    match /rankings/{docId} {
      allow read: if true;
      allow create: if isValidRankingWrite();
      allow update: if isValidRankingWrite() && isOwnerOrLegacy();
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    match /rankings_easy/{docId} {
      allow read: if true;
      allow create: if isValidRankingWrite();
      allow update: if isValidRankingWrite() && isOwnerOrLegacy();
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    match /rankings_hard/{docId} {
      allow read: if true;
      allow create: if isValidRankingWrite();
      allow update: if isValidRankingWrite() && isOwnerOrLegacy();
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ===== マッチルーム（認証必須） =====
    match /match_rooms/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ===== ニックネーム予約テーブル（UID紐付き一意性保証） =====
    // ドキュメントID = 正規化済みニックネーム（小文字化）
    // フィールド: uid, displayName（表示用の元の名前）, createdAt
    match /nicknames/{nicknameId} {
      // 認証済みユーザーのみ読み取り可（未認証からの一覧取得を防止）
      allow read: if request.auth != null;
      // 作成: 認証済み + uidが自分 + displayNameが1〜12文字
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() >= 1
                    && request.resource.data.displayName.size() <= 12;
      // 更新: 自分が所有するドキュメントのみ + uidは変更不可
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      // 削除: 自分が所有するドキュメントのみ
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // ===== ユーザー設定（本人のみ読み書き可） =====
    match /user_settings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // デフォルト: それ以外のコレクションは全て拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
